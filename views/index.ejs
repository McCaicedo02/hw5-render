<%- include("partials/head") %>
<%- include("partials/nav") %>

<main class="shell hero-layout reveal">
  <section class="hero-copy">
    <p class="eyebrow">Welcome</p>
    <h2>This site revisits HW1 through Express while keeping the original focus on operating systems.</h2>
    <p>An operating system is system software that manages hardware and software resources. It provides services for applications and helps users interact with the computer in a practical way.</p>
    <p>This revised version keeps the academic topic from the original homework, but it now includes reusable EJS partials, server-side rendering, live backend data, and package-generated study content.</p>
    <% if (weather.current) { %>
      <div class="weather-pill weather-pill--live">
        <strong><%= weather.current.temperature %>F</strong>
        <span><%= weatherLabel %> in Monterey</span>
      </div>
    <% } else { %>
      <div class="weather-pill muted">
        <span><%= weather.error %></span>
      </div>
    <% } %>
    <div class="hero-actions">
      <a href="/about" class="button-link">Read my story</a>
      <a href="/projects" class="button-link ghost">See projects</a>
    </div>
  </section>

  <section class="hero-visual">
    <div class="glass-stage">
      <div class="glass-stage__window">
        <div class="glass-stage__topline">
          <span></span>
          <span></span>
          <span></span>
        </div>
      <div class="glass-stage__content">
          <p class="tiny-label">Node package spotlight</p>
          <h3><%= study.assistant.name %></h3>
          <p><%= study.assistant.title %> focused on <%= study.assistant.focus.toLowerCase() %>.</p>
        </div>
      </div>
      <div class="glass-stage__badge glass-stage__badge--one">Express</div>
      <div class="glass-stage__badge glass-stage__badge--two">EJS</div>
      <div class="glass-stage__badge glass-stage__badge--three">API</div>
    </div>
    <div class="status-stack">
      <article class="float-card">
        <span>Mode</span>
        <strong>HW1 revised</strong>
      </article>
      <article class="float-card">
        <span>API link</span>
        <strong>Open-Meteo</strong>
      </article>
      <article class="float-card">
        <span>Current focus</span>
        <strong><%= study.assistant.focus %></strong>
      </article>
    </div>
  </section>
</main>

<section class="shell metrics-grid reveal delay-1">
  <article class="metric-card">
    <p class="eyebrow">Core functions</p>
    <h3>5</h3>
    <p>Operating systems support process management, memory management, file systems, device control, and security.</p>
  </article>
  <article class="metric-card">
    <p class="eyebrow">Study note</p>
    <h3>Faker</h3>
    <p><%= study.labNote %></p>
  </article>
  <article class="metric-card">
    <p class="eyebrow">Discussion prompt</p>
    <h3>Prompt</h3>
    <p><%= study.discussionPrompt %></p>
  </article>
</section>

<section class="shell split-band reveal delay-2">
  <article class="story-panel">
    <p class="eyebrow">Why operating systems matter</p>
    <h3>Without an operating system, most users would not be able to use a computer effectively.</h3>
    <p>The operating system allows applications to run, coordinates hardware resources, and helps different parts of the computer work together in a usable way.</p>
  </article>
  <article class="story-panel accent-panel">
    <p class="eyebrow">Live backend detail</p>
    <h3>Current Monterey weather</h3>
    <p>This weather snapshot is included through the backend to satisfy the Web API requirement while keeping the site centered on the operating systems topic.</p>
  </article>
</section>

<section class="shell ticker-band reveal delay-2" aria-label="Highlights">
  <span>EXPRESS ROUTES</span>
  <span>EJS PARTIALS</span>
  <span>OPERATING SYSTEMS</span>
  <span>BACKEND API DATA</span>
  <span>PACKAGE-DRIVEN CONTENT</span>
  <span aria-hidden="true">EXPRESS ROUTES</span>
  <span aria-hidden="true">EJS PARTIALS</span>
  <span aria-hidden="true">OPERATING SYSTEMS</span>
  <span aria-hidden="true">BACKEND API DATA</span>
  <span aria-hidden="true">PACKAGE-DRIVEN CONTENT</span>
</section>

<%- include("partials/footer") %>
