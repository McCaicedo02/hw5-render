<header class="site-header shell">
  <div class="header-topline">
    <p class="eyebrow">CST336 HW4</p>
    <span class="status-chip">Express + EJS + Live Data</span>
  </div>
  <div class="header-grid">
    <div>
      <h1>Operating Systems</h1>
      <p class="header-copy">A revised version of HW1 built with Express. This site keeps the original operating systems topic while adding backend data, reusable views, and a more developed presentation.</p>
    </div>
    <div class="header-mini-card">
      <p>This version compares major desktop operating systems while also showing Express routing, partials, and backend-driven content.</p>
    </div>
  </div>
</header>

<nav class="shell site-nav" aria-label="Main navigation">
  <% navigation.forEach((item) => { %>
    <a href="<%= item.href %>" class="<%= currentPath === item.href ? 'active' : '' %>"><%= item.label %></a>
  <% }) %>
</nav>
